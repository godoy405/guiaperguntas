<%- include('partials/header') %>
<body>
    <%- include('partials/navbar') %>
    <div class="container">
        <div class="card" id="formulario-pergunta">
            <div class="card-header">
                <h3>Realizar sua pergunta</h3>
            </div>
            <div class="card-body">
                <form method="post" action="/salvarpergunta">
                    <label>Título</label>                    
                        <input type="text" class="form-control" placeholder="Digite sua pergunta aqui..." name="titulo">
                        <label>Descrição</label>
                        <textarea class="form-control mt-2" rows="5" placeholder="Descreva sua pergunta detalhadamente..." name="descricao"></textarea>
                        <button class="btn btn-lg btn-primary mt-3">Enviar Pergunta</button>
                </form>
            </div>
        </div>   
   
    </div>    
</body>
<%- include('partials/footer') %>
