<%- include('partials/header') %>
<body>
    <%- include('partials/navbar') %>
    <div class="container">
       <hr>
       <h1><%= pergunta.titulo %></h1>
       <p><%= pergunta.descricao %></p>
       <hr>
       <form method="post" action="/responder">
        <h3>Responda a pergunta: </h3>
        <label for="corpo">Resposta:</label>
            <textarea class="form-control" placeholder="Digite sua resposta aqui..." class="form-control" name="corpo"></textarea><br>
            <input type="hidden" name="pergunta" value="<%= pergunta.id %>">
            <button class="btn btn-primary mt-2" type="submit">Responder</button>
       </form>
       <hr>
       <h3>Respostas</h3>
       <hr>
         <% respostas.forEach(resposta => { %>
                <div class="card mb-3">
                 <div class="card-body">
                      <p><%= resposta.corpo %></p>                    
                 </div>                
                </div>
          <% }); %> 
    </div >
    
</body>
<%- include('partials/footer') %>
